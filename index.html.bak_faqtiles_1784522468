function applyFreight(){
  if(!_rates)return;
  const from=document.getElementById('frFrom').value, to=document.getElementById('frTo').value,
        cust=document.getElementById('frCust').value, w=+document.getElementById('frWeight').value;
  const port=PORTS[+(document.getElementById('frPort').value||0)];
  const fx=_rates.usd_rub||90;
  if(!w||w<=0){document.getElementById('frOut').textContent='Введите вес в кг.';return;}
  const rs=_rates.rates||[], exact=rs.find(r=>r.cn===from&&r.ru===to);
  let kg, src;
  if(exact){kg=exact.usd_kg;src=window.WL?'ставка '+(WL.name||'компании'):'средняя по рынку на этом направлении';}
  else{
    const v=rs.map(r=>r.usd_kg).sort((a,b)=>a-b);
    if(!v.length){document.getElementById('frOut').textContent='Ставки накапливаются — попробуйте позже.';return;}
    kg=v[Math.floor(v.length/2)];src=window.WL?'средняя ставка '+(WL.name||'компании'):'средняя по рынку (по вашему направлению сигналов пока нет)';
  }
  const kgP=Math.round(kg*port.k*100)/100;   // поправка на плечо выбранного порта
  const rub=Math.round(kgP*w*fx);
  document.getElementById('freight').value=rub;
  window._frCustoms=cust;
  if(!window.WL)ddTrack('freight_apply',{x:{from:from,to:to,port:port.name.replace(/ \(.*/,''),rub:rub}});
  const portNote=port.k!==1?(' (плечо через '+port.name.replace(/ \(.*/,'')+', ×'+port.k+')'):'';
  document.getElementById('frOut').innerHTML='≈ '+kgP+' $/кг × '+w+' кг × '+fx+' ₽ = <b style="color:#5bffc0">'+rub.toLocaleString('ru-RU')+' ₽</b>'+portNote+'<br>'+
    from+' → '+to+' · порт: '+port.name.replace(/ \(.*/,'')+' 🕒'+port.days+' · таможня: '+cust+'<br>'+src+'.<br><b>'+(window.WL?'Это ориентир — точную ставку подтвердит менеджер.':'Это средняя по рынку — точную цену уточните у брокера справа →')+'</b>';
  _chosen=null; calc();
