// ── перетаскивание и изменение ширины блоков (сохраняем в браузере) ──
(function(){
  const wrap=document.querySelector('.calc-wrap'); if(!wrap)return;
  const cols=[...wrap.querySelectorAll('.col')];
  const slug=s=>(s||'').toLowerCase().replace(/[^а-яёa-z]+/g,'-').replace(/^-|-$/g,'').slice(0,16);
  cols.forEach(c=>{
    const head=c.querySelector('.col-head'); if(!head)return;
    c.dataset.key=slug(head.textContent);
    // ручка перетаскивания
    const grip=document.createElement('span'); grip.className='col-grip'; grip.textContent='⠿';
    grip.title='Перетащите, чтобы поменять блоки местами'; grip.setAttribute('draggable','true');
    head.insertBefore(grip,head.firstChild);
    grip.addEventListener('dragstart',e=>{c.classList.add('dragging');e.dataTransfer.setData('text',c.dataset.key);e.dataTransfer.effectAllowed='move';});
    grip.addEventListener('dragend',()=>{c.classList.remove('dragging');cols.forEach(x=>x.classList.remove('drag-over'));saveLayout();});
    // ручка ресайза
    const rz=document.createElement('div'); rz.className='col-resize'; rz.title='Потяните, чтобы изменить ширину';
    c.appendChild(rz);
    rz.addEventListener('pointerdown',e=>{
      e.preventDefault(); rz.setPointerCapture(e.pointerId);
      const x0=e.clientX, w0=c.getBoundingClientRect().width;
      const mv=ev=>{const w=Math.max(260,Math.min(w0+(ev.clientX-x0),wrap.getBoundingClientRect().width));c.style.setProperty('--w',w+'px');c.style.flexGrow='0';};
      const up=()=>{rz.removeEventListener('pointermove',mv);rz.removeEventListener('pointerup',up);saveLayout();};
      rz.addEventListener('pointermove',mv); rz.addEventListener('pointerup',up);
    });
  });
  cols.forEach(c=>{
    c.addEventListener('dragover',e=>{e.preventDefault();const d=wrap.querySelector('.dragging');if(d&&d!==c)c.classList.add('drag-over');});
    c.addEventListener('dragleave',()=>c.classList.remove('drag-over'));
    c.addEventListener('drop',e=>{e.preventDefault();c.classList.remove('drag-over');const d=wrap.querySelector('.dragging');if(!d||d===c)return;
      const rect=c.getBoundingClientRect();(e.clientX<rect.left+rect.width/2)?wrap.insertBefore(d,c):wrap.insertBefore(d,c.nextSibling);saveLayout();});
  });
  function saveLayout(){try{
    const order=[...wrap.querySelectorAll('.col')].map(c=>c.dataset.key);
    const w={}; wrap.querySelectorAll('.col').forEach(c=>{if(c.style.getPropertyValue('--w'))w[c.dataset.key]=c.style.getPropertyValue('--w');});
    localStorage.dd_layout=JSON.stringify({order:order,w:w});
  }catch(e){}}
  (function restore(){try{
    const L=JSON.parse(localStorage.dd_layout||'null'); if(!L)return;
    (L.order||[]).forEach(k=>{const c=wrap.querySelector('.col[data-key="'+k+'"]');if(c)wrap.appendChild(c);});
    Object.entries(L.w||{}).forEach(([k,v])=>{const c=wrap.querySelector('.col[data-key="'+k+'"]');if(c){c.style.setProperty('--w',v);c.style.flexGrow='0';}});
  }catch(e){}})();
})();
