let aiHistory=[];
const sleep=ms=>new Promise(r=>setTimeout(r,ms));
function addMsg(who,text){const l=document.getElementById('aiLog');const d=document.createElement('div');d.className='msg '+who;d.textContent=text;l.appendChild(d);l.scrollTop=l.scrollHeight;return d}
function addTyping(){const l=document.getElementById('aiLog');const d=document.createElement('div');d.className='msg ai typing';d.id='typing';d.innerHTML='<span>●</span><span>●</span><span>●</span>';l.appendChild(d);l.scrollTop=l.scrollHeight}
function rmTyping(){const t=document.getElementById('typing');if(t)t.remove()}
async function typeInto(id,text){const el=document.getElementById(id);el.value='';el.classList.add('filling');el.scrollIntoView({behavior:'smooth',block:'center'});for(let i=0;i<text.length;i++){el.value+=text[i];await sleep(28)}await sleep(300);el.classList.remove('filling')}
async function aiSend(){
  const inp=document.getElementById('aiMsg'),btn=document.getElementById('aiBtn'),msg=inp.value.trim();
  if(!msg)return; addMsg('user',msg); inp.value=''; btn.disabled=true;
  document.getElementById('res').style.display='none';document.getElementById('resEmpty').style.display='flex';  // прячем старый расчёт, пока ИИ уточняет
  const histForApi=aiHistory.slice(); aiHistory.push({role:'user',content:msg});
  addTyping();
  try{
    const r=await fetch(API+'/assist',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({message:msg,history:histForApi})});
    const d=await r.json(); rmTyping();
    addMsg('ai',d.reply); aiHistory.push({role:'assistant',content:d.reply});
    if(d.term){await typeInto('term',d.term);}
    if(d.qty){const qw=document.getElementById('qtyWrap');qw.style.display='block';qw.classList.add('need');const qi=document.getElementById('qty');qi.value=d.qty;qi.classList.add('filling');await sleep(500);qi.classList.remove('filling');}
    if(d.done){await sleep(500); await calc(); addMsg('ai','Готово — расчёт заполнен ниже ✓');document.getElementById('res').scrollIntoView({behavior:'smooth',block:'center'});}
  }catch(e){rmTyping();addMsg('ai','Не получилось связаться с ИИ: '+e.message);}
  finally{btn.disabled=false;inp.focus();}
}
