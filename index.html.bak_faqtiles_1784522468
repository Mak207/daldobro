// счётчики «набегают» при появлении
function countUp(el){const t=+el.dataset.n;let c=0,s=t/55;const i=setInterval(()=>{c+=s;if(c>=t){c=t;clearInterval(i)}el.textContent=Math.round(c).toLocaleString('ru-RU')},18)}
const cio=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){countUp(e.target);cio.unobserve(e.target)}}),{threshold:.6});
document.querySelectorAll('.stat b[data-n]').forEach(el=>cio.observe(el));
// ══ ВАЙТЛЕЙБЛ: модульный рендер по конфигу window.WL (сервер внедряет перед этим скриптом) ══
// blocks: порядок и состав секций; brokers_mode: daldobro | about | hide; rates: свои ставки клиента
function wlApply(){
  const W=window.WL; if(!W) return;
  {const mc=document.getElementById('marketCard'); if(mc)mc.remove();}  // наша разведка не на вайтлейбле
  document.title=(W.name||'Калькулятор')+' — расчёт ввоза из Китая';
  // бренд: логотип, имя, цвета
  const lg=document.querySelector('.logo');
  if(lg){lg.innerHTML=(W.logo?'<img src="'+W.logo+'" alt="" style="height:30px;border-radius:7px">':'')+'<span>'+(W.name||'')+'</span>';}
  if(W.colors&&W.colors.a1){
    const st=document.createElement('style');
    st.textContent='h1 .g{background:linear-gradient(100deg,'+W.colors.a1+','+(W.colors.a2||W.colors.a1)+');-webkit-background-clip:text;background-clip:text}'+
      '.btn,#freightCalc button{background:linear-gradient(100deg,'+W.colors.a1+','+(W.colors.a2||W.colors.a1)+')!important}'+
      '.ai-badge,.pill{border-color:'+W.colors.a1+'55}.col-head{color:'+W.colors.a1+'}';
    document.head.appendChild(st);
  }
  // навигация: только якоря включённых секций, без наших тарифов/каналов
  const links=document.querySelector('.links');
  if(links){const m={analytics:'Аналитика',data:'Индексы',check:'Проверка'};
    links.innerHTML='<a href="#calc">Калькулятор</a>'+(W.blocks||[]).filter(b=>m[b]).map(b=>'<a href="#'+b+'">'+m[b]+'</a>').join('')+
    (W.contacts&&W.contacts.tg?'<a href="'+W.contacts.tg+'" style="color:#5bb8ff">Telegram</a>':'');}
  // герой
  const h1=document.querySelector('.hero h1'); if(h1&&W.name)h1.innerHTML='Ввоз из Китая<br><span class="g">с компанией «'+W.name+'»</span>';
  const hp=document.querySelector('.hero .pill'); if(hp)hp.innerHTML='<span class="dot"></span> '+(W.tagline||'калькулятор себестоимости ввоза');
  // секции: убрать невключённые, расставить по порядку
  const wrap=document.querySelector('.wrap'), foot=document.querySelector('.foot');
  ['analytics','data','check'].forEach(id=>{const el=document.getElementById(id);
    if(el&&!(W.blocks||[]).includes(id))el.remove();});
  (W.blocks||[]).forEach(id=>{const el=document.getElementById(id); if(el&&id!=='calc')wrap.insertBefore(el,foot);});
  // колонка «Кто повезёт»: свои данные клиента вместо наших брокеров
  if(W.brokers_mode!=='daldobro'){
    window.loadBrokers=async()=>{};  // не дёргаем наш подбор
    const col=document.querySelector('.col-brok');
    if(col){
      if(W.brokers_mode==='hide'){col.remove();document.querySelector('.calc-wrap').style.gridTemplateColumns='1fr 1fr';}
      else{
        const c=W.contacts||{};
        col.innerHTML='<div class="col-head">'+(W.about&&W.about.title||'О компании')+'</div><div class="glass res-card">'+
          '<h3>'+(W.name||'')+'</h3><div class="bk-sub">'+(W.about&&W.about.text||'')+'</div>'+
          '<div class="bk" style="border-color:rgba(58,215,200,.45)">'+
          (c.phone?'<div class="bk-fact"><span class="k">Телефон</span><span class="v"><a href="tel:'+c.phone+'" style="color:#8fd7ff">'+c.phone+'</a></span></div>':'')+
          (c.tg?'<div class="bk-fact"><span class="k">Telegram</span><span class="v"><a href="'+c.tg+'" style="color:#8fd7ff">'+c.tg.replace('https://t.me/','@')+'</a></span></div>':'')+
          (c.email?'<div class="bk-fact"><span class="k">Почта</span><span class="v"><a href="mailto:'+c.email+'" style="color:#8fd7ff">'+c.email+'</a></span></div>':'')+
          (c.site?'<div class="bk-fact"><span class="k">Сайт</span><span class="v"><a href="'+c.site+'" target="_blank" rel="noopener" style="color:#8fd7ff">'+c.site.replace(/^https?:\/\//,'')+'</a></span></div>':'')+
          '</div><div class="bk-note">Точную ставку по вашему грузу уточняйте у нас — рассчитаем под конкретный маршрут.</div></div>';
      }
    }
  }
  // ставки клиента: мостик работает сразу, без входа, с подписью «ставка компании»
  if(W.rates&&W.rates.length){
    window.initFreightBridge=async function(){
      _rates={usd_rub:W.usd_rub||90,rates:W.rates};
      document.getElementById('freightHelp').innerHTML='<span style="color:var(--good)">✓ Наши ставки доставки</span>';
      document.getElementById('freightCalc').style.display='block';
