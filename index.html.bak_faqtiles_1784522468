            CUST=['Владивосток','Москва','Находка','Забайкальск','Уссурийск','Екатеринбург','Новосибирск','Благовещенск'];
      const opt=a=>a.map(c=>'<option>'+c+'</option>').join('');
      document.getElementById('frFrom').innerHTML=opt(CN);
      document.getElementById('frTo').innerHTML=opt(RU);
      document.getElementById('frCust').innerHTML=opt(CUST);
      document.getElementById('frPort').innerHTML=PORTS.map((p,i)=>'<option value="'+i+'">'+p.name+'</option>').join('');
      onPortChange();
    };
  }
  // подвал: клиентский + «работает на ДалДобро»
  if(foot)foot.innerHTML='<b>'+(W.name||'')+'</b> — расчёт ориентировочный, точную ставку уточняйте у менеджера.<br>'+
    (W.contacts&&W.contacts.email?W.contacts.email+' · ':'')+
    '<a href="https://daldobro.ru" style="color:#a9c2ff">работает на технологии ДалДобро</a>';
  // наши кнопки-продажи не показываем на чужой витрине
  const cl=document.querySelector('.bk-claim'); if(cl)cl.remove();
}
